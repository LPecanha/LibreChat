# Admin-ext service URL (used in production — in dev the vite proxy handles /ext)
VITE_EXT_URL=https://admin-ext.navvia.com.br

# Primary LibreChat URL (used in dev vite proxy — in production per-tenant URL is used)
VITE_LIBRECHAT_URL=http://localhost:3080

# Multi-tenant server list (baked into the build)
# JSON array with one object per LibreChat instance.
# Fields: id (must match TENANTS_CONFIG id in admin-ext), name (display), librechatUrl (public URL)
#
# Example for two Navvia tenants:
# VITE_TENANTS=[{"id":"app","name":"App Navvia","librechatUrl":"https://app.navvia.com.br"},{"id":"4leads","name":"4Leads Navvia","librechatUrl":"https://4leads.navvia.com.br"}]
#
# Leave empty for single-tenant (no server selector shown):
VITE_TENANTS=
