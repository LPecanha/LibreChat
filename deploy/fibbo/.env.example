# ── Server ────────────────────────────────────────────────────────────────────
PORT=3080
HOST=0.0.0.0
UID=1000
GID=1000

# ── App ───────────────────────────────────────────────────────────────────────
APP_TITLE=Fibbo
ALLOW_EMAIL_LOGIN=true
ALLOW_REGISTRATION=false

# ── MongoDB (centralizado) ────────────────────────────────────────────────────
# Use o nome do container ou host do MongoDB centralizado
MONGO_URI=mongodb://MONGO_USER:MONGO_PASS@mongodb_mongodb:27017/LibreChat?authSource=LibreChat

# ── Auth ──────────────────────────────────────────────────────────────────────
JWT_SECRET=
JWT_REFRESH_SECRET=
SESSION_EXPIRY=900000
REFRESH_TOKEN_EXPIRY=604800000

# ── Meilisearch ───────────────────────────────────────────────────────────────
MEILI_MASTER_KEY=

# ── RAG ───────────────────────────────────────────────────────────────────────
RAG_PORT=8000

# ── AI Providers ──────────────────────────────────────────────────────────────
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
XAI_API_KEY=
TTS_API_KEY=
SERPER_API_KEY=
FIRECRAWL_API_KEY=
FIRECRAWL_API_URL=
JINA_API_KEY=
COHERE_API_KEY=

# ── UI Defaults ──────────────────────────────────────────────────────────────
DEFAULT_LANG=pt-BR

# ── Image Generation (agent tools) ───────────────────────────────────────────
# Uses xAI Imagine API via the image_gen_oai agent tool
IMAGE_GEN_OAI_API_KEY=      # same value as XAI_API_KEY
IMAGE_GEN_OAI_BASEURL=https://api.x.ai/v1/
IMAGE_GEN_OAI_MODEL=grok-imagine-image

# ── Email (password reset) ────────────────────────────────────────────────────
EMAIL_SERVICE=
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_ENCRYPTION=starttls
EMAIL_USER=
EMAIL_PASS=
EMAIL_FROM=
EMAIL_FROM_NAME=Fibbo
