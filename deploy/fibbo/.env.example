# ── Server ────────────────────────────────────────────────────────────────────
PORT=3080
HOST=0.0.0.0
UID=1000
GID=1000

# ── App ───────────────────────────────────────────────────────────────────────
APP_TITLE=Fibbo
ALLOW_EMAIL_LOGIN=true
ALLOW_REGISTRATION=false

# ── MongoDB (centralizado) ────────────────────────────────────────────────────
# Use o nome do container ou host do MongoDB centralizado
MONGO_URI=mongodb://MONGO_USER:MONGO_PASS@mongodb_mongodb:27017/LibreChat?authSource=admin

# ── Auth ──────────────────────────────────────────────────────────────────────
JWT_SECRET=
JWT_REFRESH_SECRET=
SESSION_EXPIRY=900000
REFRESH_TOKEN_EXPIRY=604800000

# ── Meilisearch ───────────────────────────────────────────────────────────────
MEILI_MASTER_KEY=

# ── RAG ───────────────────────────────────────────────────────────────────────
RAG_PORT=8000

# ── AI Providers ──────────────────────────────────────────────────────────────
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# ── Email (password reset) ────────────────────────────────────────────────────
EMAIL_SERVICE=
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_ENCRYPTION=starttls
EMAIL_USER=
EMAIL_PASS=
EMAIL_FROM=
EMAIL_FROM_NAME=Fibbo
