# ── CORS ──────────────────────────────────────────────────────────────────────
CORS_ORIGINS=https://app.navvia.com.br,https://app.fibbo.com.br,https://admin.navvia.com.br

# ── Multi-tenant config ───────────────────────────────────────────────────────
# mongoUri aponta para o MongoDB centralizado — use o nome do container ou host
# db deve bater com o banco usado em cada MONGO_URI acima
TENANTS_CONFIG=[{"id":"navvia","name":"Navvia","mongoUri":"mongodb://NAVVIA_USER:NAVVIA_PASS@mongodb_mongodb:27017/IXLab?authSource=IXLab","db":"IXLab","jwtSecret":"JWT_SECRET_DO_NAVVIA","origin":"https://app.navvia.com.br","librechatUrl":"http://librechat-navvia:3090"},{"id":"fibbo","name":"Fibbo","mongoUri":"mongodb://FIBBO_USER:FIBBO_PASS@mongodb_mongodb:27017/LibreChat?authSource=LibreChat","db":"LibreChat","jwtSecret":"JWT_SECRET_DO_FIBBO","origin":"https://app.fibbo.com.br","librechatUrl":"http://librechat-fibbo:3080"}]

# ── Admin panel build args ────────────────────────────────────────────────────
VITE_EXT_URL=https://admin-api.navvia.com.br
VITE_TENANTS=[{"id":"navvia","name":"Navvia","librechatUrl":"https://app.navvia.com.br"},{"id":"fibbo","name":"Fibbo","librechatUrl":"https://app.fibbo.com.br"}]
VITE_LIBRECHAT_URL=

# ── Pagamentos ────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
PAGARME_API_KEY=
PAGARME_WEBHOOK_SECRET=

# ── Scheduler ─────────────────────────────────────────────────────────────────
CREDIT_SCHEDULER_CRON=0 * * * *
