EXT_PORT=3092
CORS_ORIGINS=http://localhost:3091,http://localhost:3080

# ── Multi-tenant (TENANTS_CONFIG substitui MONGO_URI e JWT_SECRET) ────────────
#
# Cada tenant tem:
#   id          — slug interno (ex: "app", "4leads")
#   name        — nome exibido no painel admin
#   mongoUri    — URI do MongoDB DAQUELE tenant (ex: mongodb://chat-mongodb-app:27017)
#   db          — nome do banco dentro do MongoDB (ex: "LibreChat")
#   jwtSecret   — JWT_SECRET definido no .env DAQUELE tenant do LibreChat
#   origin      — domínio público (para CORS e identificação automática de tenant)
#   librechatUrl — URL interna do container LibreChat (para proxy de login)
#
# Exemplo para duas instâncias Navvia:
TENANTS_CONFIG=[{"id":"app","name":"App Navvia","mongoUri":"mongodb://chat-mongodb-app:27017","db":"LibreChat","jwtSecret":"SECRET_DO_APP","origin":"https://app.navvia.com.br","librechatUrl":"http://LibreChat-app:3080"},{"id":"4leads","name":"4Leads Navvia","mongoUri":"mongodb://chat-mongodb-4leads:27017","db":"LibreChat","jwtSecret":"SECRET_DO_4LEADS","origin":"https://4leads.navvia.com.br","librechatUrl":"http://LibreChat-4leads:3080"}]

# ── Modo single-tenant (alternativa — use se não usar TENANTS_CONFIG) ─────────
# MONGO_URI=mongodb://localhost:27017/LibreChat
# JWT_SECRET=your-librechat-jwt-secret-here

# ── Pagamentos ────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
PAGARME_API_KEY=ak_test_...
PAGARME_WEBHOOK_SECRET=your-pagarme-webhook-secret

# ── Scheduler ─────────────────────────────────────────────────────────────────
CREDIT_SCHEDULER_CRON=0 * * * *

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=info
